<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Code Review Report -- {{ repo_name }}</title>
  <meta name="description" content="Automated code review audit report for {{ repo_name }} generated on {{ generated_at }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-primary: #0d0f14;
      --bg-secondary: #141720;
      --bg-card: #1a1e2e;
      --bg-card-hover: #1f2438;
      --border: #2a2f45;
      --border-light: #363d58;
      --text-primary: #e8eaf6;
      --text-secondary: #9099b7;
      --text-muted: #5c6380;
      --accent-blue: #4f8ef7;
      --accent-purple: #8b5cf6;
      --accent-cyan: #22d3ee;

      --critical: #ff4757;
      --critical-bg: rgba(255, 71, 87, 0.08);
      --critical-border: rgba(255, 71, 87, 0.25);

      --high: #ff6b35;
      --high-bg: rgba(255, 107, 53, 0.08);
      --high-border: rgba(255, 107, 53, 0.25);

      --medium: #ffd32a;
      --medium-bg: rgba(255, 211, 42, 0.08);
      --medium-border: rgba(255, 211, 42, 0.25);

      --low: #2ed573;
      --low-bg: rgba(46, 213, 115, 0.08);
      --low-border: rgba(46, 213, 115, 0.25);

      --info: #4f8ef7;
      --info-bg: rgba(79, 142, 247, 0.08);
      --info-border: rgba(79, 142, 247, 0.25);

      --radius: 12px;
      --radius-sm: 8px;
      --shadow: 0 4px 24px rgba(0,0,0,0.4);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
    }

    /* -- Header -- */
    .header {
      background: linear-gradient(135deg, #0d0f14 0%, #141a2e 50%, #0d1220 100%);
      border-bottom: 1px solid var(--border);
      padding: 48px 0 40px;
      position: relative;
      overflow: hidden;
    }

    .header::before {
      content: '';
      position: absolute;
      top: -60px; left: -60px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(79,142,247,0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .header::after {
      content: '';
      position: absolute;
      bottom: -80px; right: -40px;
      width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(139,92,246,0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 32px;
      position: relative;
      z-index: 1;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(79,142,247,0.12);
      border: 1px solid rgba(79,142,247,0.25);
      border-radius: 100px;
      padding: 4px 14px;
      font-size: 12px;
      font-weight: 500;
      color: var(--accent-blue);
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent-blue);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .header h1 {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #e8eaf6 30%, #8b9fc7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 10px;
    }

    .header-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 20px;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .header-meta span {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* -- Stats Bar -- */
    .stats-bar {
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border);
      padding: 24px 0;
    }

    .stats-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 32px;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .stat-card {
      flex: 1;
      min-width: 140px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .stat-number {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -1px;
    }

    .stat-label {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-card.critical .stat-number { color: var(--critical); }
    .stat-card.high .stat-number { color: var(--high); }
    .stat-card.medium .stat-number { color: var(--medium); }
    .stat-card.low .stat-number { color: var(--low); }
    .stat-card.total .stat-number { color: var(--accent-blue); }

    /* -- Filter Bar -- */
    .filter-bar {
      max-width: 1100px;
      margin: 32px auto 0;
      padding: 0 32px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .filter-label {
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .filter-btn {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 13px;
      font-family: inherit;
      color: var(--text-secondary);
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn:hover, .filter-btn.active {
      border-color: var(--accent-blue);
      color: var(--accent-blue);
      background: rgba(79,142,247,0.08);
    }

    .filter-btn[data-sev="critical"]:hover,
    .filter-btn[data-sev="critical"].active { border-color: var(--critical); color: var(--critical); background: var(--critical-bg); }

    .filter-btn[data-sev="high"]:hover,
    .filter-btn[data-sev="high"].active { border-color: var(--high); color: var(--high); background: var(--high-bg); }

    .filter-btn[data-sev="medium"]:hover,
    .filter-btn[data-sev="medium"].active { border-color: var(--medium); color: var(--medium); background: var(--medium-bg); }

    .filter-btn[data-sev="low"]:hover,
    .filter-btn[data-sev="low"].active { border-color: var(--low); color: var(--low); background: var(--low-bg); }

    /* -- Issues Section -- */
    .issues-section {
      max-width: 1100px;
      margin: 24px auto 60px;
      padding: 0 32px;
    }

    .section-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .no-issues {
      text-align: center;
      padding: 80px 20px;
      color: var(--text-muted);
    }

    .no-issues-icon {
      font-size: 48px;
      margin-bottom: 16px;
      font-weight: 700;
      color: var(--low);
    }

    .no-issues h3 { font-size: 20px; color: var(--text-secondary); margin-bottom: 8px; }

    /* -- Issue Card -- */
    .issue-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 16px;
      overflow: hidden;
      transition: box-shadow 0.2s, transform 0.2s;
      animation: fadeSlideIn 0.3s ease both;
    }

    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .issue-card:hover {
      box-shadow: var(--shadow);
      transform: translateY(-1px);
    }

    .issue-card.critical { border-left: 3px solid var(--critical); }
    .issue-card.high     { border-left: 3px solid var(--high); }
    .issue-card.medium   { border-left: 3px solid var(--medium); }
    .issue-card.low      { border-left: 3px solid var(--low); }
    .issue-card.info     { border-left: 3px solid var(--info); }

    .issue-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 20px 24px;
      cursor: pointer;
      user-select: none;
    }

    .issue-header:hover { background: var(--bg-card-hover); }

    .severity-badge {
      flex-shrink: 0;
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .severity-badge.critical { background: var(--critical-bg); color: var(--critical); border: 1px solid var(--critical-border); }
    .severity-badge.high     { background: var(--high-bg);     color: var(--high);     border: 1px solid var(--high-border); }
    .severity-badge.medium   { background: var(--medium-bg);   color: var(--medium);   border: 1px solid var(--medium-border); }
    .severity-badge.low      { background: var(--low-bg);      color: var(--low);      border: 1px solid var(--low-border); }
    .severity-badge.info     { background: var(--info-bg);     color: var(--info);     border: 1px solid var(--info-border); }

    .issue-title-block { flex: 1; min-width: 0; }

    .issue-type {
      font-size: 11px;
      font-family: 'JetBrains Mono', monospace;
      color: var(--text-muted);
      margin-bottom: 4px;
    }

    .issue-message {
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.4;
    }

    .issue-location {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      font-size: 12px;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
    }

    .source-tag {
      background: rgba(139,92,246,0.12);
      color: var(--accent-purple);
      border: 1px solid rgba(139,92,246,0.2);
      border-radius: 4px;
      padding: 1px 6px;
      font-size: 10px;
      font-family: 'JetBrains Mono', monospace;
    }

    .expand-icon {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 16px;
      transition: transform 0.25s;
      border: 1px solid var(--border);
      border-radius: 50%;
    }

    .issue-card.expanded .expand-icon {
      transform: rotate(180deg);
    }

    /* -- Issue Body (collapsible) -- */
    .issue-body {
      display: none;
      padding: 0 24px 24px;
      border-top: 1px solid var(--border);
    }

    .issue-card.expanded .issue-body { display: block; }

    .issue-sections {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 20px;
    }

    @media (max-width: 700px) {
      .issue-sections { grid-template-columns: 1fr; }
    }

    .issue-section {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 16px;
    }

    .issue-section.full-width {
      grid-column: 1 / -1;
    }

    .issue-section-title {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .issue-section p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .evidence-block {
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 12px 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: #a8b4d0;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.7;
    }

    /* -- Footer -- */
    .footer {
      text-align: center;
      padding: 32px;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: var(--text-muted);
    }

    /* -- Scrollbar -- */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg-primary); }
    ::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
  </style>
</head>
<body>

<!-- Header -->
<header class="header">
  <div class="header-inner">
    <div class="badge"><span class="badge-dot"></span>Code Review Agent</div>
    <h1>{{ repo_name }}</h1>
    <div class="header-meta">
      <span>{{ total_files }} files scanned</span>
      <span>{{ total_issues }} issues found</span>
      <span>{{ generated_at }}</span>
      <span>Gemini 2.5 Pro + radon + bandit</span>
    </div>
  </div>
</header>

<!-- Stats -->
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-card total">
      <div class="stat-number">{{ total_issues }}</div>
      <div class="stat-label">Total Issues</div>
    </div>
    <div class="stat-card critical">
      <div class="stat-number">{{ counts.critical }}</div>
      <div class="stat-label">Critical</div>
    </div>
    <div class="stat-card high">
      <div class="stat-number">{{ counts.high }}</div>
      <div class="stat-label">High</div>
    </div>
    <div class="stat-card medium">
      <div class="stat-number">{{ counts.medium }}</div>
      <div class="stat-label">Medium</div>
    </div>
    <div class="stat-card low">
      <div class="stat-number">{{ counts.low }}</div>
      <div class="stat-label">Low</div>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
  <span class="filter-label">Filter:</span>
  <button class="filter-btn active" data-filter="all">All</button>
  <button class="filter-btn" data-sev="critical" data-filter="critical">Critical</button>
  <button class="filter-btn" data-sev="high"     data-filter="high">High</button>
  <button class="filter-btn" data-sev="medium"   data-filter="medium">Medium</button>
  <button class="filter-btn" data-sev="low"      data-filter="low">Low</button>
  <button class="filter-btn" data-filter="heuristic">Static Analysis</button>
  <button class="filter-btn" data-filter="ai">AI Analysis</button>
</div>

<!-- Issues -->
<main class="issues-section">
  {% if issues %}
    <div class="section-title">{{ total_issues }} findings -- sorted by severity</div>

    {% for issue in issues %}
    {% set sev = issue.severity | lower %}
    {% set src = issue.source | default('heuristic') %}
    {% set is_ai = 'ai' in src %}

    <div class="issue-card {{ sev }}"
         data-severity="{{ sev }}"
         data-source="{{ 'ai' if is_ai else 'heuristic' }}"
         id="issue-{{ loop.index }}">
      <div class="issue-header" onclick="toggleIssue(this.parentElement)">
        <span class="severity-badge {{ sev }}">{{ sev }}</span>
        <div class="issue-title-block">
          <div class="issue-type">{{ issue.type | replace('_', ' ') | upper }}</div>
          <div class="issue-message">{{ issue.message }}</div>
          <div class="issue-location">
            <span>{{ issue.file }}</span>
            {% if issue.line %}<span>line {{ issue.line }}</span>{% endif %}
            <span class="source-tag">{{ 'AI' if is_ai else 'static' }}</span>
          </div>
        </div>
        <span class="expand-icon">v</span>
      </div>

      <div class="issue-body">
        <div class="issue-sections">
          <div class="issue-section">
            <div class="issue-section-title">What We Observed</div>
            <p>{{ issue.message }}</p>
          </div>

          <div class="issue-section">
            <div class="issue-section-title">Likely Root Cause</div>
            <p>{{ issue.root_cause | default('Not determined by static analysis.') }}</p>
          </div>

          <div class="issue-section">
            <div class="issue-section-title">Recommended Fix</div>
            <p>{{ issue.recommended_fix | default('See issue message for guidance.') }}</p>
          </div>

          {% if issue.evidence %}
          <div class="issue-section full-width">
            <div class="issue-section-title">Evidence</div>
            <div class="evidence-block">{{ issue.evidence }}</div>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% endfor %}

  {% else %}
    <div class="no-issues">
      <div class="no-issues-icon">OK</div>
      <h3>No issues found</h3>
      <p>Your repository looks clean. No significant issues were detected.</p>
    </div>
  {% endif %}
</main>

<footer class="footer">
  Generated by <strong>Code Review Agent</strong> &middot; {{ generated_at }} &middot;
  Powered by Gemini 2.5 Pro + radon + bandit
</footer>

<script>
  function toggleIssue(card) {
    card.classList.toggle('expanded');
  }

  const filterBtns = document.querySelectorAll('.filter-btn');
  const issueCards = document.querySelectorAll('.issue-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter;
      issueCards.forEach(card => {
        if (filter === 'all') {
          card.style.display = '';
        } else if (filter === 'heuristic' || filter === 'ai') {
          card.style.display = card.dataset.source === filter ? '' : 'none';
        } else {
          card.style.display = card.dataset.severity === filter ? '' : 'none';
        }
      });
    });
  });

  document.querySelectorAll('.issue-card').forEach((card, i) => {
    card.style.animationDelay = `${i * 40}ms`;
  });
</script>
</body>
</html>
